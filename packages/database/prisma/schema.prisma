generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  OPS
  MECHANIC
  ADMIN
}

enum BookingStatus {
  CREATED
  CONFIRMED
  PICKUP_ASSIGNED
  PICKED_UP
  RECEIVED_AT_SERVICE_CENTER
  INSPECTION_COMPLETED
  AWAITING_CUSTOMER_APPROVAL
  APPROVED_FOR_SERVICE
  IN_SERVICE
  QUALITY_CHECK
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum BookingActorType {
  CUSTOMER
  OPS
  MECHANIC
  ADMIN
  SYSTEM
}

enum InspectionIssueSeverity {
  CRITICAL
  RECOMMENDED
  OPTIONAL
}

enum IssueApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceOrderStatus {
  CREATED
  INSPECTION
  IN_SERVICE
  QUALITY_CHECK
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum ServiceTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DONE
  SKIPPED
}

enum MediaProofType {
  PHOTO
  VIDEO
  CCTV_CLIP
  DOCUMENT
}

enum MediaVisibility {
  INTERNAL
  CUSTOMER_VISIBLE
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

model User {
  id                String                 @id @default(cuid())
  firebaseUid       String                 @unique
  email             String?                @unique
  phone             String?                @unique
  role              UserRole               @default(CUSTOMER)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  customerProfile   CustomerProfile?
  uploadedProofs    MediaProof[]           @relation("ProofUploadedBy")
  notificationLogs  NotificationDelivery[]
}

model CustomerProfile {
  id           String                @id @default(cuid())
  userId       String                @unique
  fullName     String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id])
  addresses    Address[]
  motorcycles  Motorcycle[]
  bookings     Booking[]
  history      ServiceHistoryEvent[]

  @@index([fullName])
}

model Address {
  id          String          @id @default(cuid())
  customerId  String
  label       String
  line1       String
  line2       String?
  city        String
  state       String
  pincode     String
  latitude    Decimal?        @db.Decimal(10, 7)
  longitude   Decimal?        @db.Decimal(10, 7)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  customer    CustomerProfile @relation(fields: [customerId], references: [id])
  pickupFor   Booking[]       @relation("PickupAddress")
  dropFor     Booking[]       @relation("DropAddress")

  @@index([customerId])
  @@index([pincode])
}

model Motorcycle {
  id                 String          @id @default(cuid())
  customerId         String
  registrationNumber String          @unique
  brand              String
  model              String
  variant            String?
  year               Int?
  odometerKm         Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  customer           CustomerProfile @relation(fields: [customerId], references: [id])
  bookings           Booking[]

  @@index([customerId])
  @@index([brand, model])
}

model ServiceCenter {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  addressLine1  String
  city          String
  state         String
  pincode       String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  serviceOrders ServiceOrder[]
}

model ServicePackage {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  description      String?
  motorcycleBrand  String?
  motorcycleModel  String?
  fixedPrice       Decimal   @db.Decimal(10, 2)
  estimatedMinutes Int
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bookings         Booking[]

  @@index([isActive])
  @@index([motorcycleBrand, motorcycleModel])
}

model Booking {
  id                String          @id @default(cuid())
  customerId        String
  motorcycleId      String
  servicePackageId  String
  pickupAddressId   String
  dropAddressId     String
  preferredPickupAt DateTime
  status            BookingStatus   @default(CREATED)
  quotedPrice       Decimal         @db.Decimal(10, 2)
  customerNotes     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customer          CustomerProfile @relation(fields: [customerId], references: [id])
  motorcycle        Motorcycle      @relation(fields: [motorcycleId], references: [id])
  servicePackage    ServicePackage  @relation(fields: [servicePackageId], references: [id])
  pickupAddress     Address         @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  dropAddress       Address         @relation("DropAddress", fields: [dropAddressId], references: [id])
  serviceOrder      ServiceOrder?
  timelineEvents    BookingTimelineEvent[]
  inspectionReport  InspectionReport?

  @@index([customerId])
  @@index([motorcycleId])
  @@index([status])
  @@index([preferredPickupAt])
}

model BookingTimelineEvent {
  id          String           @id @default(cuid())
  bookingId   String
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  actorType   BookingActorType
  actorId     String?
  actorName   String
  note        String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  booking     Booking          @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@index([toStatus])
  @@index([actorType])
}

model InspectionReport {
  id             String            @id @default(cuid())
  bookingId      String            @unique
  summary        String?
  createdByType  BookingActorType
  createdById    String?
  createdByName  String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  booking        Booking           @relation(fields: [bookingId], references: [id])
  issues         InspectionIssue[]

  @@index([createdAt])
}

model InspectionIssue {
  id                    String                  @id @default(cuid())
  reportId              String
  title                 String
  description           String?
  severity              InspectionIssueSeverity
  estimatedPartsCost    Decimal                 @db.Decimal(10, 2)
  estimatedLaborCost    Decimal                 @db.Decimal(10, 2)
  imageUrls             Json?
  approvalStatus        IssueApprovalStatus     @default(PENDING)
  customerDecisionAt    DateTime?
  customerDecisionById  String?
  customerDecisionByName String?
  customerDecisionNote  String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  report                InspectionReport        @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([severity])
  @@index([approvalStatus])
}

model ServiceOrder {
  id              String                @id @default(cuid())
  bookingId       String                @unique
  serviceCenterId String?
  status          ServiceOrderStatus    @default(CREATED)
  finalAmount     Decimal?              @db.Decimal(10, 2)
  startedAt       DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  booking         Booking               @relation(fields: [bookingId], references: [id])
  serviceCenter   ServiceCenter?        @relation(fields: [serviceCenterId], references: [id])
  tasks           ServiceTask[]
  partsUsed       ServiceOrderPart[]
  proofs          MediaProof[]
  historyEvents   ServiceHistoryEvent[]
}

model ServiceTask {
  id             String            @id @default(cuid())
  serviceOrderId String
  name           String
  description    String?
  status         ServiceTaskStatus @default(PENDING)
  assignedMechanicId   String?
  assignedMechanicName String?
  proofRequired  Boolean           @default(true)
  startedAt      DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  serviceOrder   ServiceOrder      @relation(fields: [serviceOrderId], references: [id])
  partsUsed      ServiceOrderPart[]
  proofs         MediaProof[]

  @@index([serviceOrderId, status])
  @@index([assignedMechanicId, status])
}

model Part {
  id             String             @id @default(cuid())
  sku            String             @unique
  name           String
  manufacturer   String
  isGenuine      Boolean            @default(true)
  warrantyMonths Int?
  mrp            Decimal            @db.Decimal(10, 2)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  serviceUsage   ServiceOrderPart[]
}

model ServiceOrderPart {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceTaskId  String?
  partId         String
  quantity       Int
  unitPrice      Decimal      @db.Decimal(10, 2)
  batchCode      String?
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  serviceTask    ServiceTask? @relation(fields: [serviceTaskId], references: [id])
  part           Part         @relation(fields: [partId], references: [id])

  @@index([serviceOrderId])
  @@index([serviceTaskId])
  @@index([partId])
}

model MediaProof {
  id              String          @id @default(cuid())
  serviceOrderId  String
  serviceTaskId   String?
  uploadedById    String?
  type            MediaProofType
  visibility      MediaVisibility @default(CUSTOMER_VISIBLE)
  storageProvider String
  storageKey      String
  mimeType        String?
  durationSeconds Int?
  capturedAt      DateTime?
  createdAt       DateTime        @default(now())
  serviceOrder    ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  serviceTask     ServiceTask?    @relation(fields: [serviceTaskId], references: [id])
  uploadedBy      User?           @relation("ProofUploadedBy", fields: [uploadedById], references: [id])
}

model ServiceHistoryEvent {
  id             String          @id @default(cuid())
  customerId     String
  serviceOrderId String
  eventType      String
  title          String
  description    String?
  metadata       Json?
  occurredAt     DateTime        @default(now())
  customer       CustomerProfile @relation(fields: [customerId], references: [id])
  serviceOrder   ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
}

model NotificationDelivery {
  id          String              @id @default(cuid())
  userId      String?
  channel     NotificationChannel
  templateKey String
  status      NotificationStatus  @default(QUEUED)
  providerId  String?
  error       String?
  createdAt   DateTime            @default(now())
  sentAt       DateTime?
  user        User?               @relation(fields: [userId], references: [id])
}
