# App
NODE_ENV=development
API_PORT=4000
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Neon PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/mototrust?sslmode=require
AUTH_BOOTSTRAP_KEY=replace-me

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# Firebase
FIREBASE_PROJECT_ID=mototrust-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_FIREBASE_API_KEY=replace-me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mototrust-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mototrust-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mototrust-dev.appspot.com

# Media storage
MEDIA_STORAGE_PROVIDER=firebase
MEDIA_PROOF_BUCKET=mototrust-service-proof-dev
